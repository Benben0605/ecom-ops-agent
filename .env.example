# Chat 模型（DeepSeek，OpenAI 兼容接口）
LLM_API_KEY=your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Embedding 模型（通义，DeepSeek 无 embedding 接口）
EMBED_API_KEY=your-dashscope-key
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBED_MODEL=text-embedding-v3

# 换模型只改对应 BASE_URL + MODEL：
# OpenAI: LLM_BASE_URL=https://api.openai.com/v1   LLM_MODEL=gpt-4o-mini
# 通义chat: LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   LLM_MODEL=qwen-plus
